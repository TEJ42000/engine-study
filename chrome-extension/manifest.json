{
  "manifest_version": 3,
  "name": "Engine Study - Brightspace Sync",
  "version": "2.0",
  "description": "Detect and upload course materials from Brightspace to Engine Study.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "https://*.brightspace.com/*",
    "https://*.brightspace.nl/*",
    "https://*.rug.nl/*",
    "https://*.augmentusercontent.com/*",
    "https://webapp-theta-beige.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.brightspace.com/*",
        "https://*.brightspace.nl/*",
        "https://*.rug.nl/*"
      ],
      "js": ["content.js"]
    }
  ]
}
